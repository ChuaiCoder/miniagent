# ============================================================================
# C++ / CMake / Windows 项目 .gitignore
# ============================================================================

# ----------------------------------------------------------------------------
# 构建目录（CMake 输出、FetchContent 缓存等）
# ----------------------------------------------------------------------------
build/
out/
cmake-build-*/
_deps/
CMakeFiles/
CMakeUserPresets.json

# ----------------------------------------------------------------------------
# CMake 生成文件
# ----------------------------------------------------------------------------
CMakeCache.txt
CMakeError.log
CMakeOutput.log
cmake_install.cmake
install_manifest.txt
compile_commands.json
*.cmake
!CMakeLists.txt
!**/CMakeLists.txt

# ----------------------------------------------------------------------------
# 编译产物（MSVC / GCC / Clang）
# ----------------------------------------------------------------------------
*.obj
*.o
*.a
*.so
*.so.*
*.dylib
*.dll
*.lib
*.exe
*.out
*.app

# 调试与链接中间文件
*.pdb
*.ilk
*.idb
*.exp
*.map
*.tlog
*.recipe
*.lastbuildstate

# ----------------------------------------------------------------------------
# Visual Studio / MSBuild 产物
# ----------------------------------------------------------------------------
*.sln
*.vcxproj
*.vcxproj.filters
*.vcxproj.user
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.aps
*.ncb
*.opensdf
*.sdf
*.cachefile

# ----------------------------------------------------------------------------
# IDE 与编辑器
# ----------------------------------------------------------------------------
# Visual Studio Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains（CLion / Rider 等）
.idea/
*.iml

# Vim / Emacs
*.swp
*.swo
*~
\#*\#
.\#*

# Sublime Text
*.sublime-workspace
*.sublime-project

# ----------------------------------------------------------------------------
# 操作系统产生的文件
# ----------------------------------------------------------------------------
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon?

# Linux
*~
.directory
.Trash-*

# ----------------------------------------------------------------------------
# 日志与临时文件
# ----------------------------------------------------------------------------
*.log
logs/
*.tmp
*.temp
*.bak
*.backup

# ----------------------------------------------------------------------------
# 敏感信息（API Key、密钥、配置等，切勿提交）
# ----------------------------------------------------------------------------
.env
.env.*
*.pem
*.key
*.p12
*.pfx
secrets.*
config.local.*

# ----------------------------------------------------------------------------
# 测试与覆盖率
# ----------------------------------------------------------------------------
coverage/
*.gcov
*.gcda
*.gcno
*.profraw
*.profdata

# ----------------------------------------------------------------------------
# 依赖与第三方库（FetchContent 会自动拉取，不入库）
# ----------------------------------------------------------------------------
third_party/
3rdparty/
vendor/
